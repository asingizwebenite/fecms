# =============================================================
# TWZ FEMS - Fire Extinguisher Management System
# Environment Variables Example
# Copy this file to .env and fill in the values
# =============================================================

# ── PostgreSQL ────────────────────────────────────────────────
# Primary connection string (recommended — works with Supabase, Neon, Railway, local, etc.)
# Format: postgresql://<user>:<password>@<host>:<port>/fecms_new
DATABASE_URL=postgresql://postgres:<password>@localhost:5432/fecms_new

# Individual connection vars (used as fallback if DATABASE_URL is not set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fecms_new
POSTGRES_USER=postgres
POSTGRES_PASSWORD=4208

# ── JWT ──────────────────────────────────────────────────────
# Secret key for signing JWT tokens (use a long random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your_refresh_secret_key_change_this
JWT_REFRESH_EXPIRES_IN=30d

# ── Service Ports ─────────────────────────────────────────────
GATEWAY_PORT=3000
USER_SERVICE_PORT=3001
AUTH_SERVICE_PORT=3002
EXTINGUISHER_SERVICE_PORT=3003
INSPECTION_SERVICE_PORT=3004
REPORTING_SERVICE_PORT=3005
NOTIFICATION_SERVICE_PORT=3006

# ── Service Internal URLs (used for inter-service communication)
USER_SERVICE_URL=http://localhost:3001
AUTH_SERVICE_URL=http://localhost:3002
EXTINGUISHER_SERVICE_URL=http://localhost:3003
INSPECTION_SERVICE_URL=http://localhost:3004
REPORTING_SERVICE_URL=http://localhost:3005
NOTIFICATION_SERVICE_URL=http://localhost:3006

# ── Email / SMTP (used by Notification Service for OTP emails) ─
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM="TWZ FEMS <noreply@twzfems.com>"

# ── Frontend ──────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000/api

# ── App ───────────────────────────────────────────────────────
NODE_ENV=development
FRONTEND_URL=http://localhost:5173

# ── OTP Settings ──────────────────────────────────────────────
OTP_EXPIRY_MINUTES=30

# ── Admin Seed (auto-created on first startup if no Admin exists) ─
# These credentials are used once — change them immediately after first login
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Admin
ADMIN_EMAIL=admin@twzfems.com
ADMIN_PASSWORD=Admin@1234




